# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Instagram Downloader API"
APP_VERSION="1.0.0"
DEBUG=false
ALLOWED_ORIGINS=["*"]

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://mongo:27017
MONGODB_DB_NAME=instagram_downloader

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
QUEUE_NAME=instagram_download_queue
QUEUE_MAX_RETRIES=3
WORKER_CONCURRENCY=4

# ── Instagram / InstaLoader ────────────────────────────────────────────────────
# Leave blank to run anonymously (public content only)
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTALOADER_SESSION_FILE=/tmp/instaloader_session

# ── Storage ───────────────────────────────────────────────────────────────────
DOWNLOAD_DIR=/data/downloads
MEDIA_BASE_URL=http://localhost:8000/media
